<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//ibatis.apache.org//DTD Mapper 3.0//EN" 
						"http://ibatis.apache.org/dtd/ibatis-3-mapper.dtd">
<mapper namespace="kr.co.green.test.mapper.ListMapper">

	<resultMap id="listResultMap" type="kr.co.green.test.dto.ListDTO">
		<result property="id" column="id"></result>
		<result property="title" column="title"></result>
		<result property="author" column="author"></result>
		<result property="createdDate" column="created_date"></result>
	</resultMap>
	<select id="getAllPosts" resultMap="listResultMap">
	
		SELECT *
		FROM (
			SELECT
				   title,
				   author,
				   created_date,
				   ROW_NUMBER() OVER (ORDER BY created_date DESC) AS rn
			FROM posts_test
		)
		WHERE rn BETWEEN #{pi.offset} AND #{pi.limit}
	</select>
	
	<select id="getTotalCount">
		SELECT COUNT(*) FROM posts_test
		
	</select>
	
	
</mapper>